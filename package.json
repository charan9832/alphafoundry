{
  "name": "alphafoundry",
  "version": "0.1.0",
  "description": "A local-first Pi-powered terminal AI agent with simple af commands and finance tools planned later.",
  "type": "module",
  "bin": {
    "af": "./dist/src/cli.js",
    "alphafoundry": "./dist/src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run build && npm run test",
    "dev": "tsx src/cli.ts",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/src/**",
    "README.md",
    "AGENTS.md",
    "docs/**"
  ]
}
