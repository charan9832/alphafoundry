{
  "name": "alphafoundry",
  "version": "0.3.0",
  "description": "AlphaFoundry: a native terminal AI workspace with a React Ink TUI and Pi runtime adapter.",
  "type": "module",
  "bin": {
    "af": "./src/cli.js",
    "alphafoundry": "./src/cli.js"
  },
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "check": "npm test && node src/cli.js --help && node src/cli.js --version && npm run pack:dry-run && npm run smoke:installed",
    "claude:validate": "node scripts/validate-claude-setup.mjs",
    "pack:dry-run": "npm pack --dry-run --json",
    "smoke:installed": "node scripts/smoke-installed.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "chalk": "^5.6.2",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "slice-ansi": "^9.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "tsx": "^4.21.0",
    "wrap-ansi": "^10.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "files": [
    "src",
    "scripts/run-tests.mjs",
    "scripts/smoke-installed.mjs",
    "scripts/validate-claude-setup.mjs",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md",
    "docs",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "AlphaFoundry contributors",
  "homepage": "https://github.com/charan9832/alphafoundry#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charan9832/alphafoundry.git"
  },
  "bugs": {
    "url": "https://github.com/charan9832/alphafoundry/issues"
  },
  "keywords": [
    "alphafoundry",
    "ai-agent",
    "tui",
    "ink",
    "terminal",
    "pi-agent"
  ]
}
