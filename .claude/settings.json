{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(npm test*)",
      "Bash(npm run check*)",
      "Bash(npm run pack:dry-run*)",
      "Bash(npm run smoke:installed*)",
      "Bash(node *)",
      "Bash(find .claude*)"
    ],
    "ask": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*_rsa)",
      "Read(**/*_ed25519)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(curl *|sh)",
      "Bash(wget *|sh)"
    ]
  },
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  }
}
