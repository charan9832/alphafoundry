{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "Bash(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*_rsa)",
      "Read(**/*_ed25519)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.npmrc)",
      "Read(**/.git-credentials)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git rebase*)",
      "Bash(curl *|sh)",
      "Bash(wget *|sh)"
    ]
  },
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  }
}
